{
  "name": "codex-session-viewer",
  "version": "1.0.0",
  "description": "本地网页会话查看器，用于浏览 Codex 本地会话历史。",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "test": "node --test",
    "lint": "eslint server public --fix",
    "format": "prettier --write .",
    "build": "vite build"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "vite": "^6.3.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
